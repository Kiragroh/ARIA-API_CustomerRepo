       ] ;
       fhir:name [ fhir:v "Radiotherapy Course Summary" ] ;
       fhir:description [ fhir:v "A summary of the treatment progress in a radiotherapy course of treatment.\r\nWhen additional treatments are delivered in the same course, this resource is updated. No new resource is created." ] ;
       fhir:example [ fhir:v "false"^^xsd:boolean ]
