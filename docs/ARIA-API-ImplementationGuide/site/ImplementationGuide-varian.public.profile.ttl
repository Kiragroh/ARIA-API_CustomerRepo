       fhir:reference [
         fhir:link <http://varian.com/fhir/v1/StructureDefinition/RadiotherapyCoursePrescription> ;
         fhir:reference [ fhir:v "StructureDefinition/RadiotherapyCoursePrescription" ]
       ] ;
       fhir:name [ fhir:v "Radiotherapy Course Prescription" ] ;
       fhir:description [ fhir:v "The elements of a treatment course that can be defined during prescription. This represents the treatment course in ARIA, not an actual prescription and is the parent for all presciptions in the course.\r\nIt contains the data elements of a course that are not specific to planning or delivery, for example, treatment intent, relation to the diagnosis, or course status.\r\nThose elements are exposed as CodeX RT Radiotherapy Course Prescription although ARIA does not have an actual prescription for the complete course. See the Phase Prescription profile for actual prescriptions in ARIA.\r\nWith the Radiotherapy Course Prescription, elements of the course can be found as soon as a course is defined in ARIA, even if no treatment plans or delivered treatments are available yet." ] ;
       fhir:example [ fhir:v "false"^^xsd:boolean ]
     ] [
       fhir:extension ( [
         fhir:url [ fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ] ;
