       fhir:name [ fhir:v "Radiotherapy Planned Course" ] ;
       fhir:description [ fhir:v "A summary of all plans in a radiotherapy course of treatment. Only approved plans with status other than Unapproved, Rejected, Reviewed are considered." ] ;
