       fhir:path [ fhir:v "Organization.extension" ] ;
       fhir:slicing [
         fhir:discriminator ( [
           fhir:type [ fhir:v "value" ] ;
           fhir:path [ fhir:v "url" ]
         ] ) ;
         fhir:ordered [ fhir:v "false"^^xsd:boolean ] ;
         fhir:rules [ fhir:v "open" ]
       ]
     ] [
       fhir:id [ fhir:v "Organization.extension:isChargeCaptureApplicable" ] ;
       fhir:path [ fhir:v "Organization.extension" ] ;
       fhir:sliceName [ fhir:v "isChargeCaptureApplicable" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Extension"^^xsd:anyURI ] ;
         fhir:profile ( [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/isChargeCaptureApplicable"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/isChargeCaptureApplicable>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Organization.identifier" ] ;
       fhir:path [ fhir:v "Organization.identifier" ] ;
       fhir:definition [ fhir:v "Identifier for the organization that is used to identify the organization across multiple disparate systems.\nHospital-\nValue-HospitalSer\nDepartment-\nValue-DepartmentSer." ] ;
       fhir:comment [ fhir:v "dept → Department Id" ] ;
       fhir:requirements [ fhir:v "* Organizations are known by a variety of ids. Some institutions maintain several, and most collect identifiers for exchange with other organizations concerning the organization.\n\n* Type of identifiers:\n    * type:dept- Department Id" ]
     ] [
       fhir:id [ fhir:v "Organization.identifier.use" ] ;
       fhir:path [ fhir:v "Organization.identifier.use" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Organization.identifier.system" ] ;
       fhir:path [ fhir:v "Organization.identifier.system" ] ;
       fhir:short [ fhir:v "System uri for identifier" ] ;
       fhir:comment [ fhir:v "Systems\n- System for DepartmentId: http://Varian.com/fhir/identifier/Organization/dept/Id." ]
     ] [
       fhir:id [ fhir:v "Organization.identifier.value" ] ;
       fhir:path [ fhir:v "Organization.identifier.value" ] ;
       fhir:short [ fhir:v "identifier value" ] ;
       fhir:comment [ fhir:v "Id\n- Department Id: Id of the dpeartment." ]
     ] [
       fhir:id [ fhir:v "Organization.identifier.period" ] ;
       fhir:path [ fhir:v "Organization.identifier.period" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Organization.identifier.assigner" ] ;
       fhir:path [ fhir:v "Organization.identifier.assigner" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Organization.active" ] ;
       fhir:path [ fhir:v "Organization.active" ] ;
       fhir:definition [ fhir:v "Whether the organization's record is still in active use.\nActive flag indicates whether the Hospital/Department is 'Active', 'Inactive'." ] ;
       fhir:comment [ fhir:v "Default is true.  This active flag is not intended to be used to mark an organizations as temporarily closed or under construction. Instead the Location(s) within the Organization should have the suspended status. If further details of the reason for the suspension are required, then an extension on this element should be used.  This element is labeled as a modifier because it may be used to mark that the resource was created in error." ]
     ] [
       fhir:id [ fhir:v "Organization.type" ] ;
       fhir:path [ fhir:v "Organization.type" ] ;
       fhir:short [ fhir:v "prov | dept" ] ;
       fhir:definition [ fhir:v "The kind(s) of organization that this is.\nHospital-\nSystem- http://hl7.org/fhir/organization-type\nCode- prov\nDisplay- Healthcare Provider\nDepartment-\nSystem- http://hl7.org/fhir/organization-type\nCode- dept\nDisplay- Hospital Department." ] ;
       fhir:comment [ fhir:v "Organizations can be corporations, wards, sections, clinical teams, government departments, etc. Note that code is generally a classifier of the type of organization; in many applications, codes are used to identity a particular organization (say, ward) as opposed to another of the same type - these are identifiers, not codes  When considering if multiple types are appropriate, you should evaluate if child organizations would be a more appropriate use of the concept, as different types likely are in different sub-areas of the organization. This is most likely to be used where type values have orthogonal values, such as a religious, academic and medical center.  We expect that some jurisdictions will profile this optionality to be a single cardinality.\n\nSupported types\n-ul-\n-li-\nsystem: http://terminology.hl7.org/CodeSystem/organization-type\n-/li-\n-/ul-\n\n-ul-\n-li-\ncode: 'prov' for Hospital\n-/li-\n-li-\ncode: 'dept' for Department\n-/li-\n-/ul-." ]
     ] [
       fhir:id [ fhir:v "Organization.name" ] ;
       fhir:path [ fhir:v "Organization.name" ] ;
       fhir:definition [ fhir:v "A name associated with the organization\nHospital-\nName of the hospital, External identification.\nDepartment-\nName of the departemnt." ]
     ] [
       fhir:id [ fhir:v "Organization.alias" ] ;
       fhir:path [ fhir:v "Organization.alias" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Organization.telecom" ] ;
       fhir:path [ fhir:v "Organization.telecom" ] ;
       fhir:definition [ fhir:v "A contact detail for the organization. Type of contact details are phone, fax, url(web)." ]
     ] [
       fhir:id [ fhir:v "Organization.telecom.system" ] ;
