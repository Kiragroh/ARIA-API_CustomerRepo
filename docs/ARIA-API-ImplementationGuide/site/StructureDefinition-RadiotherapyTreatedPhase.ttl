         fhir:severity [ fhir:v "warning" ] ;
         fhir:human [ fhir:v "Only Phase Ids 'Primary' or 'Boost' are supported. This is a current ARIA limitation. The Phase Id is modelled as Identifier to support more general identifiers in the future." ] ;
         fhir:expression [ fhir:v "(system = 'http://varian.com/fhir/identifier/radiotherapyPhaseId') implies (value = 'Primary' or value = 'Boost')" ] ;
         fhir:source [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/RadiotherapyTreatedPhase"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/RadiotherapyTreatedPhase>
         ]
       ] )
     ] [
       fhir:id [ fhir:v "Procedure.identifier:displayName" ] ;
       fhir:path [ fhir:v "Procedure.identifier" ] ;
       fhir:sliceName [ fhir:v "displayName" ] ;
       fhir:short [ fhir:v "Display name is the Prescription ID in ARIA and unique for the patient." ]
     ] [
       fhir:id [ fhir:v "Procedure.identifier:displayName.system" ] ;
       fhir:path [ fhir:v "Procedure.identifier.system" ] ;
       fhir:pattern [ fhir:v "http://varian.com/fhir/identifier/radiotherapyPrescriptionId"^^xsd:anyURI ]
     ] [
       fhir:id [ fhir:v "Procedure.identifier:official" ] ;
       fhir:path [ fhir:v "Procedure.identifier" ] ;
       fhir:sliceName [ fhir:v "official" ] ;
       fhir:short [ fhir:v "ARIA identifier that is unique for this instance of ARIA and serves as primary database key." ]
     ] [
       fhir:id [ fhir:v "Procedure.identifier:official.system" ] ;
       fhir:path [ fhir:v "Procedure.identifier.system" ] ;
       fhir:pattern [ fhir:v "http://varian.com/fhir/identifier/RadiotherapyPhase/RadOnc-Id"^^xsd:anyURI ]
     ] [
       fhir:id [ fhir:v "Procedure.identifier:phaseId" ] ;
       fhir:path [ fhir:v "Procedure.identifier" ] ;
       fhir:sliceName [ fhir:v "phaseId" ] ;
       fhir:short [ fhir:v "Identifier that annotates which treatement phase is covered by this prescription. ARIA supports 'Primary' or 'Boost'." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "*" ] ;
       fhir:mustSupport [ fhir:v "true"^^xsd:boolean ]
     ] [
       fhir:id [ fhir:v "Procedure.identifier:phaseId.use" ] ;
       fhir:path [ fhir:v "Procedure.identifier.use" ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ] ;
       fhir:pattern [ fhir:v "secondary" ]
     ] [
       fhir:id [ fhir:v "Procedure.identifier:phaseId.system" ] ;
       fhir:path [ fhir:v "Procedure.identifier.system" ] ;
       fhir:pattern [ fhir:v "http://varian.com/fhir/identifier/radiotherapyPhaseId"^^xsd:anyURI ]
     ] [
       fhir:id [ fhir:v "Procedure.basedOn" ] ;
       fhir:path [ fhir:v "Procedure.basedOn" ] ;
       fhir:short [ fhir:v "See slicing in base profile." ]
     ] [
       fhir:id [ fhir:v "Procedure.basedOn:planned-phase" ] ;
       fhir:path [ fhir:v "Procedure.basedOn" ] ;
       fhir:sliceName [ fhir:v "planned-phase" ] ;
       fhir:short [ fhir:v "ARIA references the Radiotherapy Planned Phase." ]
     ] [
       fhir:id [ fhir:v "Procedure.basedOn:phase-prescription" ] ;
       fhir:path [ fhir:v "Procedure.basedOn" ] ;
       fhir:sliceName [ fhir:v "phase-prescription" ] ;
       fhir:short [ fhir:v "Prescription for this phase." ]
     ] [
       fhir:id [ fhir:v "Procedure.partOf" ] ;
       fhir:path [ fhir:v "Procedure.partOf" ] ;
       fhir:short [ fhir:v "See slicing in base profile." ]
     ] [
       fhir:id [ fhir:v "Procedure.partOf:course-summary" ] ;
       fhir:path [ fhir:v "Procedure.partOf" ] ;
       fhir:sliceName [ fhir:v "course-summary" ] ;
       fhir:short [ fhir:v "ARIA references the Radiotherapy Course Summary." ]
     ] [
       fhir:id [ fhir:v "Procedure.status" ] ;
       fhir:path [ fhir:v "Procedure.status" ] ;
       fhir:short [ fhir:v "Mapped from the status of course and prescription in ARIA." ]
     ] [
       fhir:id [ fhir:v "Procedure.category" ] ;
       fhir:path [ fhir:v "Procedure.category" ] ;
       fhir:short [ fhir:v "Fixed code for radiotherapy defined by CodeX RT." ]
     ] [
       fhir:id [ fhir:v "Procedure.code" ] ;
       fhir:path [ fhir:v "Procedure.code" ] ;
       fhir:short [ fhir:v "Fixed code for radiotherapy treatment phase defined by CodeX RT." ]
     ] [
       fhir:id [ fhir:v "Procedure.subject" ] ;
       fhir:path [ fhir:v "Procedure.subject" ] ;
       fhir:short [ fhir:v "Patient who receives or received the radiotherapy treatment described in this resource." ]
     ] [
       fhir:id [ fhir:v "Procedure.subject.display" ] ;
       fhir:path [ fhir:v "Procedure.subject.display" ] ;
       fhir:short [ fhir:v "Name of the patient 'Last Name, First Name'." ]
     ] [
       fhir:id [ fhir:v "Procedure.performed[x].start" ] ;
       fhir:path [ fhir:v "Procedure.performed[x].start" ] ;
       fhir:short [ fhir:v "Date of the first treatment in this phase." ]
     ] [
       fhir:id [ fhir:v "Procedure.performed[x].end" ] ;
       fhir:path [ fhir:v "Procedure.performed[x].end" ] ;
       fhir:short [ fhir:v "Date of that latest treatment in this phase at the time this summary was created. If additional treatments are delivered in this phase, then this end date is updated accordingly." ]
     ] [
       fhir:id [ fhir:v "Procedure.reasonCode" ] ;
       fhir:path [ fhir:v "Procedure.reasonCode" ] ;
       fhir:short [ fhir:v "Codes of the assigned diagoses. Note that in ARIA, multiple alternative codes may be assigned to each single diagnosis." ]
     ] [
       fhir:id [ fhir:v "Procedure.reasonReference" ] ;
       fhir:path [ fhir:v "Procedure.reasonReference" ] ;
       fhir:short [ fhir:v "References to the Condition resources that represent the assigned diagnoses. May reference multiple Condition resources for the same diagnosis if alternative code systems are used." ]
     ] [
       fhir:id [ fhir:v "Procedure.bodySite" ] ;
       fhir:path [ fhir:v "Procedure.bodySite" ] ;
       fhir:short [ fhir:v "Body site to which radiotherapy is prescribed." ] ;
       fhir:comment [ fhir:v "The body site of an ARIA Prescription is bound to a user editable list\r\nand in FHIR exposed as CodeSystem http://varian.com/fhir/CodeSystem/radiotherapy-prescription-site.\r\nAdditionally, the code is mapped to SNOMED CT codes of the mCODE Radiotnerapy Treatment Location ValueSet where possible." ] ;
       fhir:max [ fhir:v "1" ]
     ] )
  ] . # 

