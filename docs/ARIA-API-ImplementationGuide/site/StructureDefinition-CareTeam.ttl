  fhir:differential [
     fhir:element ( [
       fhir:id [ fhir:v "CareTeam.id" ] ;
       fhir:path [ fhir:v "CareTeam.id" ] ;
       fhir:short [ fhir:v "'Careteam-' + PatientSer.ResourceName(CareTeam) in ID should be in exact case as FHIR resource name." ] ;
       fhir:definition [ fhir:v "Logical id of this artifact. It has following structrure'Careteam-' + PatientSer.\n\nResourceName(CareTeam) in ID should be in exact case as FHIR resource name." ] ;
       fhir:comment [ fhir:v "Composed as 'CareTeam-' + Patient.PatientSer." ] ;
       fhir:min [ fhir:v "1"^^xsd:nonNegativeInteger ]
     ] [
       fhir:id [ fhir:v "CareTeam.meta.versionId" ] ;
       fhir:path [ fhir:v "CareTeam.meta.versionId" ] ;
       fhir:mustSupport [ fhir:v "true"^^xsd:boolean ]
     ] [
       fhir:id [ fhir:v "CareTeam.meta.lastUpdated" ] ;
       fhir:path [ fhir:v "CareTeam.meta.lastUpdated" ] ;
       fhir:mustSupport [ fhir:v "true"^^xsd:boolean ]
     ] [
       fhir:id [ fhir:v "CareTeam.identifier" ] ;
       fhir:path [ fhir:v "CareTeam.identifier" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "CareTeam.status" ] ;
       fhir:path [ fhir:v "CareTeam.status" ] ;
       fhir:definition [ fhir:v "* proposed | active | suspended | inactive | entered-in-error\n\n* 1. system:  http://hl7.org/fhir/care-team-status\n* 2. code: active." ] ;
       fhir:comment [ fhir:v "* 1. system:  http://hl7.org/fhir/care-team-status\n* 2. code: active." ]
     ] [
       fhir:id [ fhir:v "CareTeam.category" ] ;
       fhir:path [ fhir:v "CareTeam.category" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "CareTeam.name" ] ;
       fhir:path [ fhir:v "CareTeam.name" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "CareTeam.subject" ] ;
       fhir:path [ fhir:v "CareTeam.subject" ] ;
       fhir:comment [ fhir:v "Patient in ARIA.(Mandatory)." ]
     ] [
       fhir:id [ fhir:v "CareTeam.encounter" ] ;
       fhir:path [ fhir:v "CareTeam.encounter" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "CareTeam.period" ] ;
       fhir:path [ fhir:v "CareTeam.period" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "CareTeam.participant" ] ;
       fhir:path [ fhir:v "CareTeam.participant" ] ;
       fhir:short [ fhir:v "Members of the team, Can be a Hospital, Department or a Practitioner (Doctor / Staff)" ] ;
       fhir:definition [ fhir:v "Members of the team, Can be a Hospital, Department or a Practitioner (Doctor / Staff)." ] ;
       fhir:comment [ fhir:v "\n* List of Validations of members:\n\n    *  Hospital\n        * 1. Default Hospital is mandatory.\n        * 2. Only one Hospital can be set as Default Hospital.\n\n    *  Department\n        * 1. If no primary departments is provided in payload then default hospital's one department gets assigned as primary department.\n        * 2. Only one Department can be set as Default Department.\n        * 3. New onBehalfOf field has been introduced for department participant which will have a reference to the associated Organization(Hospital) in ARIA. (Supported only on ARIA V18 or onwards)\n\n    *  Practitioner\n        * 1. Only one Oncologist can be set as Primary Oncologist per hospital in CareTeam.\n        * 2. New onBehalfOf field has been introduced for oncologist, primary oncologist or staff participant which will have a reference to the associated Organization(Hospital) in ARIA. (Supported only on ARIA V18 or onwards)\n        * 3. Only one Physician can be set as Primary Physician in CareTeam.\n" ]
     ] [
       fhir:id [ fhir:v "CareTeam.participant.role" ] ;
       fhir:path [ fhir:v "CareTeam.participant.role" ] ;
       fhir:short [ fhir:v "Type of involvement, supports 2 code systems - https://ncit.nci.nih.gov and http://varian.com/fhir/r4/code-systems/CareTeam/careteam-participant-role" ] ;
       fhir:definition [ fhir:v "Type of involvement, supports 2 code systems - https://ncit.nci.nih.gov and http://varian.com/fhir/r4/code-systems/CareTeam/careteam-participant-role." ] ;
       fhir:comment [ fhir:v "* http://varian.com/fhir/r4/code-systems/CareTeam/careteam-participant-role is mandatory for CareTeam create/update. \n* It can be of the following codes: \n    * 1. default-hospital\n    * 2. service-organization, \n    * 3. default-service-organization, \n    * 4. oncologist, primary-oncologist, \n    * 5. referring-physician, \n    * 6. primary-referring-physician and \n    * 7. staff. \n\n* For Primary Care Physician role, system: http://loinc.org and code: 56802-2." ]
     ] [
       fhir:id [ fhir:v "CareTeam.participant.member" ] ;
       fhir:path [ fhir:v "CareTeam.participant.member" ] ;
       fhir:short [ fhir:v "Who is involved, can be a Department, Hospital or a Practitioner (Doctor / Staff)" ] ;
       fhir:comment [ fhir:v "Who is involved, can be a Department, Hospital or a Practitioner (Doctor / Staff), also have support for Identifier during create/update if Reference value is not known." ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Reference"^^xsd:anyURI ] ;
         fhir:targetProfile ( [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Practitioner"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Practitioner>
         ] [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Organization"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Organization>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "CareTeam.participant.onBehalfOf" ] ;
       fhir:path [ fhir:v "CareTeam.participant.onBehalfOf" ] ;
       fhir:short [ fhir:v "Reference of hospital asoociated for Practitioner/Department in ARIA. (Supported only on ARIA V18 or onwards)" ] ;
       fhir:definition [ fhir:v "The organization (hospital) of the practitioner/department." ] ;
       fhir:comment [ fhir:v "Reference of hospital asoociated for Practitioner/Department in ARIA. (Supported only on ARIA V18 or onwards)" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Reference"^^xsd:anyURI ] ;
         fhir:targetProfile ( [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Organization"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Organization>
         ] )
       ] )
     ] [
