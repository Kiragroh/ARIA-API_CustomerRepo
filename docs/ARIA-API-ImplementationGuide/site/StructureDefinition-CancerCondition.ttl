       fhir:path [ fhir:v "Condition.verificationStatus" ] ;
       fhir:short [ fhir:v "provisional | confirmed |entered-in-error" ] ;
       fhir:definition [ fhir:v "The verification status to support the clinical status of the condition. Indicates whether the diagnosis/problem has been confirmed as being present (confirmed) or whether it is just suspected (provisional).\n[encounter-diagnosis] - \nprovisional | confirmed  | entered-in-error\n[problem-list-item] - \nprovisional | confirmed  | entered-in-error\n[Medical Problem] - \nThis field is not applicable in Medical Problem." ] ;
       fhir:comment [ fhir:v "Introduced search of non errored(valid) records using ':not' modifier, a validation message will be provided if user tries to search using any other status or a list of statuses, only supported status is 'entered-in-error'." ]
     ] [
       fhir:id [ fhir:v "Condition.category" ] ;
       fhir:path [ fhir:v "Condition.category" ] ;
       fhir:short [ fhir:v "encounter-diagnosis|problem-list-item" ] ;
       fhir:definition [ fhir:v "A category assigned to the condition.Fixed Value: encounter-diagnosis .\n\nCode is Mapped from http://terminology.hl7.org/CodeSystem/condition-category." ]
     ] [
       fhir:id [ fhir:v "Condition.severity" ] ;
       fhir:path [ fhir:v "Condition.severity" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Condition.code" ] ;
       fhir:path [ fhir:v "Condition.code" ] ;
       fhir:short [ fhir:v "clinical description of diagnosis." ] ;
       fhir:definition [ fhir:v "This is a user-specified clinical description of the diagnosis or problem.\n\ncode = Cancer code\n\nsystem = Selected ICD code scheme\n\ndisplay = Cancer code description." ] ;
       fhir:comment [ fhir:v "Patient Diagnosis value of clinical description.\nFor multiple diagnosis codes - Additional diagnosis codes are not validated before Create and Update and System, Code and Display is Mandatory for Additional diagnosis." ] ;
       fhir:binding [
         fhir:strength [ fhir:v "required" ] ;
         fhir:valueSet [
           fhir:v "http://varian.com/fhir/ValueSet/condition-code"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/ValueSet/condition-code>
         ]
       ]
     ] [
       fhir:id [ fhir:v "Condition.bodySite" ] ;
       fhir:path [ fhir:v "Condition.bodySite" ] ;
       fhir:short [ fhir:v "ARIA Coded body site. Anatomical location, if relevant." ] ;
       fhir:definition [ fhir:v "The anatomical location where this condition manifests itself. This is the site of the primary cancer.\n\nCode:- The three digit code which identifies the topographic site of the tumor.  The first two digits represent a major site and the third digit represents a subdivision within the location.\nExtension:-  A number used to sort several locations which are all coded to the same site.  The number one is used to identify the preferred site.\nDisplay:- Description of the topographic site.\nSystem:- The name of this classification scheme." ] ;
       fhir:comment [ fhir:v " This is the site of the primary cancer.This gives Information about Diagnosis site,ICD-O site and Primary site." ]
     ] [
       fhir:id [ fhir:v "Condition.bodySite.extension:condition-laterality" ] ;
       fhir:path [ fhir:v "Condition.bodySite.extension" ] ;
       fhir:sliceName [ fhir:v "condition-laterality" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Extension"^^xsd:anyURI ] ;
         fhir:profile ( [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/condition-laterality"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/condition-laterality>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Condition.subject" ] ;
       fhir:path [ fhir:v "Condition.subject" ] ;
       fhir:short [ fhir:v "Who has the condition? i.e. Patient" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Reference"^^xsd:anyURI ] ;
         fhir:targetProfile ( [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Patient"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Patient>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Condition.encounter" ] ;
       fhir:path [ fhir:v "Condition.encounter" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Condition.onset[x]" ] ;
       fhir:path [ fhir:v "Condition.onset[x]" ] ;
       fhir:short [ fhir:v "Estimated or actual date,  date-time" ] ;
       fhir:comment [ fhir:v "Value is taken from Patient Diagnosis onset_date_cd or onset_date." ] ;
       fhir:type ( [
         fhir:code [ fhir:v "dateTime"^^xsd:anyURI ]
       ] [
         fhir:code [ fhir:v "string"^^xsd:anyURI ]
       ] )
     ] [
       fhir:id [ fhir:v "Condition.abatement[x]" ] ;
       fhir:path [ fhir:v "Condition.abatement[x]" ] ;
       fhir:short [ fhir:v "If/when in resolution/remission. Diagnosis Status Date when status is resolved | remission" ] ;
       fhir:definition [ fhir:v "The date or estimated date that the condition resolved or went into remission. This is called \"abatement\" because of the many overloaded connotations associated with \"remission\" or \"resolution\" - Conditions are never really resolved, but they can abate.\n\nDiagnosis Status Date when status is resolved | remission." ] ;
       fhir:type ( [
         fhir:code [ fhir:v "dateTime"^^xsd:anyURI ]
       ] )
     ] [
       fhir:id [ fhir:v "Condition.recordedDate" ] ;
       fhir:path [ fhir:v "Condition.recordedDate" ] ;
       fhir:short [ fhir:v "Date record was believed accurate i.e. Created On date" ] ;
       fhir:definition [ fhir:v "The date on which the existance of the Condition was first asserted or acknowledged." ] ;
       fhir:comment [ fhir:v "While creation this property will be ignored and date will be auto generated." ]
     ] [
       fhir:id [ fhir:v "Condition.recorder" ] ;
       fhir:path [ fhir:v "Condition.recorder" ] ;
       fhir:short [ fhir:v "Person who asserts this condition" ] ;
       fhir:definition [ fhir:v "Provider who is Creating the condition." ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Reference"^^xsd:anyURI ] ;
         fhir:targetProfile ( [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Practitioner"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Practitioner>
         ] [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Patient"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Patient>
         ] [
           fhir:v "http://hl7.org/fhir/StructureDefinition/RelatedPerson"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/RelatedPerson>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Condition.asserter" ] ;
       fhir:path [ fhir:v "Condition.asserter" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Condition.stage" ] ;
       fhir:path [ fhir:v "Condition.stage" ] ;
       fhir:short [ fhir:v "Stage/grade, usually assessed formally. Cancer Stage group." ] ;
       fhir:comment [ fhir:v "Cancer Stage group." ]
     ] [
       fhir:id [ fhir:v "Condition.stage.summary" ] ;
       fhir:path [ fhir:v "Condition.stage.summary" ] ;
       fhir:definition [ fhir:v "A simple summary of the stage such as \"Stage 3\". The determination of the stage is disease-specific.\nThis is the staging information for the diagnosis, where applicable.\n[encounter-diagnosis] - \nCalculated stage based on criteria and scheme." ]
     ] [
       fhir:id [ fhir:v "Condition.stage.assessment" ] ;
       fhir:path [ fhir:v "Condition.stage.assessment" ] ;
       fhir:short [ fhir:v "Reference to a formal record of the evidence on which the staging assessment is based." ] ;
       fhir:definition [ fhir:v "Reference to a formal record of the evidence on which the staging assessment is based.\nStage Group Level Observation\nstage.assesment (Display) - Concatenated String of Stage Criteria." ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Reference"^^xsd:anyURI ] ;
         fhir:targetProfile ( [
           fhir:v "http://hl7.org/fhir/StructureDefinition/Observation"^^xsd:anyURI ;
           fhir:link <http://hl7.org/fhir/StructureDefinition/Observation>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Condition.stage.type" ] ;
       fhir:path [ fhir:v "Condition.stage.type" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Condition.evidence.code" ] ;
       fhir:path [ fhir:v "Condition.evidence.code" ] ;
       fhir:short [ fhir:v "DiagnosisMethodCode" ] ;
       fhir:definition [ fhir:v "A manifestation or symptom that led to the recording of this condition\nA unique key to describe a diagnosis method type.\nCode= Diagnosis Method code\n-ul-\n-li-ARIA System Code -/li-\n-li-Mapping Table for Loinc -/li-\n-/ul-\nSystem= ARIA System code\nDisplay= Diagnosis Method code display\nText= Diagnosis Method description." ] ;
       fhir:comment [ fhir:v "DiagnosisMethodCode" ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Condition.evidence.detail" ] ;
       fhir:path [ fhir:v "Condition.evidence.detail" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Condition.note" ] ;
       fhir:path [ fhir:v "Condition.note" ] ;
       fhir:definition [ fhir:v "Additional information about the Condition. This is a general notes/comments entry  for description of the Condition, its diagnosis and prognosis.\nA description of the diagnosis/problem as defined by the user." ] ;
       fhir:comment [ fhir:v "A description of the diagnosis/problem as defined by the user." ] ;
       fhir:max [ fhir:v "1" ]
     ] )
  ] . # 

