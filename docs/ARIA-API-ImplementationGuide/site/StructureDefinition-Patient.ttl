       fhir:comment [ fhir:v "Family name is Last name of patient." ] ;
       fhir:maxLength [ fhir:v "64"^^xsd:integer ]
     ] [
       fhir:id [ fhir:v "Patient.name.given" ] ;
       fhir:path [ fhir:v "Patient.name.given" ] ;
       fhir:definition [ fhir:v "Given names (not always 'first'). Includes middle names." ] ;
       fhir:comment [ fhir:v "Given name is First name and  maiden name of patient." ] ;
