       fhir:path [ fhir:v "Patient.deceased[x]" ] ;
       fhir:sliceName [ fhir:v "deceasedDateTime" ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
         fhir:code [ fhir:v "dateTime"^^xsd:anyURI ]
       ] )
     ] [
       fhir:id [ fhir:v "Patient.address.id" ] ;
       fhir:path [ fhir:v "Patient.address.id" ] ;
       fhir:definition [ fhir:v "Unique id for inter-element referencing." ]
     ] [
       fhir:id [ fhir:v "Patient.address.extension:isPrimary" ] ;
       fhir:path [ fhir:v "Patient.address.extension" ] ;
       fhir:sliceName [ fhir:v "isPrimary" ] ;
       fhir:short [ fhir:v "Whether the patient address is primary?" ] ;
       fhir:definition [ fhir:v "* Whether the patient address is primary?\n\n* Patient temp address is mapped to ARIA local 1 and local 2 address.\n    *  If temp address isPrimary=true, then temp address is mapped with local-1 address of patient.\n    *  If temp address isPrimary=false, then temp address is mapped with local-2 address of patient." ] ;
       fhir:min [ fhir:v "0"^^xsd:nonNegativeInteger ] ;
       fhir:max [ fhir:v "1" ] ;
       fhir:type ( [
