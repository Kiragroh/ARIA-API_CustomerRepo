       fhir:comment [ fhir:v "Suffix to the patient name, examples (Jr., Sr., PHD, ...)." ] ;
       fhir:maxLength [ fhir:v "16"^^xsd:integer ]
     ] [
       fhir:id [ fhir:v "Patient.name.period" ] ;
       fhir:path [ fhir:v "Patient.name.period" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Patient.telecom.id" ] ;
       fhir:path [ fhir:v "Patient.telecom.id" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Patient.telecom.extension" ] ;
       fhir:path [ fhir:v "Patient.telecom.extension" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
