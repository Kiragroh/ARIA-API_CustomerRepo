       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Patient.active" ] ;
       fhir:path [ fhir:v "Patient.active" ] ;
       fhir:definition [ fhir:v "Whether this patient's record is in active use." ] ;
       fhir:comment [ fhir:v "true → ActivePatient (default), false → ArchivedPatient | ArchivePending | DeletedPatient." ]
     ] [
       fhir:id [ fhir:v "Patient.name" ] ;
       fhir:path [ fhir:v "Patient.name" ] ;
       fhir:definition [ fhir:v "A name associated with the patient. See comment for more information." ] ;
       fhir:comment [ fhir:v "* The following are mapping for Aria Patient Names:\n\n    * official → Official Name  (ARIA First, Last, Middle Name and Prefix/Suffix),\n    * maiden → Maiden Name (ARIA Patient Maiden Name),\n    * usual → Preferred Name (Patient Preferred Name),\n    * old → Previous Name (Patient Previous Name).\n\n* Other Fhir name.use are considered as Patient Multiple Names.\n\n* Below are the validation Performed on Patient.name. :\n\n    * At least one name should be present.\n    * Max Name 6 are supported (except maiden name).\n    * If Only one Name without Use is present in request - Internally name.use = Offical is assigned.\n    * Only one Official name is supported.\n    * Only one Usual name is supported.\n    * Only one Old name is supported.\n    * Official name should have Lastname.\n    * Internally Name Representation code for Official name is set to  Null.\n    * For Official Name NameSelectedForDisplay=1 is assigned.\n    * For Usual or Old Name Internally NameRepresentationCode is set to as Alphabetic(ABC/A).\n    * More than one Ideographic(IDE)/(I) Patient names not supported.\n    * For NameRepresentationCode = IDE(I) Internally NameSelctedForDisplay is set to PreviousNameSelctedForDisplay + 1.\n    * For NameRepresentationCode = Symbolic (SYL)/Phonetic(P) Internally NameSelctedForDisplay is set to PreviousNameSelctedForDisplay + 1.\n    * More than one Symbolic (SYL)/Phonetic(P) Patient names not supported." ]
     ] [
       fhir:id [ fhir:v "Patient.name.id" ] ;
       fhir:path [ fhir:v "Patient.name.id" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Patient.name.use" ] ;
       fhir:path [ fhir:v "Patient.name.use" ] ;
       fhir:definition [ fhir:v "usual | official | temp | nickname | anonymous | old | maiden." ] ;
       fhir:comment [ fhir:v "* The following are supported:\n\n    * official → Official Name  (ARIA First, Last, Middle Name and Prefix/Suffix),\n\n    * maiden → Maiden Name (ARIA Patient Maiden Name),\n\n    * usual → Preferred Name (Patient Preferred Name),\n\n    * old → Previous Name (Patient Previous Name)" ]
     ] [
       fhir:id [ fhir:v "Patient.name.text" ] ;
       fhir:path [ fhir:v "Patient.name.text" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Patient.name.family" ] ;
       fhir:path [ fhir:v "Patient.name.family" ] ;
