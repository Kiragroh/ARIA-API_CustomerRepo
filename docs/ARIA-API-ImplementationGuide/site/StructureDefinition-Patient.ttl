     ] [
       fhir:id [ fhir:v "Patient.gender" ] ;
       fhir:path [ fhir:v "Patient.gender" ] ;
       fhir:definition [ fhir:v "male | female | other | unknown." ] ;
       fhir:comment [ fhir:v "Supported genders are: male | female | other | unknown, if gender in ARIA(eg: Transsexual or Not Stated) is not representable by any of these then the gender attribute will be 'unknown' and ARIA gender represented as 'http://varian.com/fhir/r4/StructureDefinition/v2/person-gender' extension. Search on gender attribute is case insensitive and works on both Administrative gender and person-gender extension. While create/update preference given to person-gender extension.\nPatient Gender Create and Update implemented as follows - \nOperation(Create)-RequestValue(Valid)-Value Set In DB(Valid Lookup value)\nOperation(Create)-RequestValue(null)-Value Set In DB(Default if present else Null) \nOperation(Create)-RequestValue(Invalid)-Value Set In DB(Null) and warning is provided\nOperation(Update)-RequestValue(Valid)-Value Set In DB(Valid Lookup value) \nOperation(Update)-RequestValue(null)-Value Set In DB(Null)\nOperation(Update)-RequestValue(Invalid)-Value Set In DB(Null) and warning is provided." ] ;
       fhir:maxLength [ fhir:v "16"^^xsd:integer ]
     ] [
       fhir:id [ fhir:v "Patient.birthDate" ] ;
       fhir:path [ fhir:v "Patient.birthDate" ] ;
       fhir:maxLength [ fhir:v "23"^^xsd:integer ]
     ] [
       fhir:id [ fhir:v "Patient.deceased[x]" ] ;
       fhir:path [ fhir:v "Patient.deceased[x]" ] ;
       fhir:slicing [
         fhir:discriminator ( [
