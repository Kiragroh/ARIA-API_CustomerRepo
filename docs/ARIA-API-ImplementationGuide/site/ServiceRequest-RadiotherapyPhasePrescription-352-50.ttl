  fhir:text [
     fhir:status [ fhir:v "extensions" ] ;
     fhir:div "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p><b>Generated Narrative: ServiceRequest</b><a name=\"RadiotherapyPhasePrescription-352-50\"> </a></p><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\">Resource ServiceRequest &quot;RadiotherapyPhasePrescription-352-50&quot; Version &quot;3249827&quot; Updated &quot;2022-12-02 15:50:45+0100&quot; </p><p style=\"margin-bottom: 0px\">Profiles: <a href=\"http://hl7.org/fhir/us/codex-radiation-therapy/STU1/StructureDefinition-codexrt-radiotherapy-phase-prescription.html\">Radiotherapy Phase Prescription</a>, <code>http://fhir.siemens-healthineers.com/fhir/R4/StructureDefinition/shs-radiotherapy-phase-prescription-service-request</code>, <a href=\"StructureDefinition-RadiotherapyPhasePrescription.html\">Radiotherapy Phase Prescription</a></p></div><p><b>Procedure Intent Extension</b>: Radical <span style=\"background: LightGoldenRodYellow; margin: 4px; border: 1px solid khaki\"> (radiotherapy-therapeutic-intent#Radical)</span></p><blockquote><p><b>Radiotherapy Modality And Technique Extension</b></p><blockquote><p><b>url</b></p><a href=\"http://hl7.org/fhir/us/mcode/STU2.1/StructureDefinition-mcode-radiotherapy-modality.html\">Radiotherapy Modality Extension</a></blockquote><p><b>value</b>: External beam radiation therapy using electrons (procedure) <span style=\"background: LightGoldenRodYellow; margin: 4px; border: 1px solid khaki\"> (<a href=\"https://browser.ihtsdotools.org/\">SNOMED CT</a>#45643008)</span></p><blockquote><p><b>url</b></p><a href=\"http://hl7.org/fhir/us/mcode/STU2.1/StructureDefinition-mcode-radiotherapy-technique.html\">Radiotherapy Technique Extension</a></blockquote><p><b>value</b>: Conformal <span style=\"background: LightGoldenRodYellow; margin: 4px; border: 1px solid khaki\"> (radiotherapy-prescription-technique#Conformal; <a href=\"http://terminology.hl7.org/6.0.2/CodeSystem-v3-NullFlavor.html\">NullFlavor</a>#UNC &quot;un-encoded&quot;)</span></p></blockquote><p><b>Number of Prescribed Fractions</b>: 4</p><blockquote><p><b>Dose Prescribed to Volume</b></p><blockquote><p><b>url</b></p><code>volume</code></blockquote><p><b>value</b>: <span>: Left Breast Boost</span></p><blockquote><p><b>url</b></p><code>fractionDose</code></blockquote><p><b>value</b>: 200.0 cGy<span style=\"background: LightGoldenRodYellow\"> (Details: UCUM code cGy = 'cGy')</span></p><blockquote><p><b>url</b></p><code>totalDose</code></blockquote><p><b>value</b>: 800.0 cGy<span style=\"background: LightGoldenRodYellow\"> (Details: UCUM code cGy = 'cGy')</span></p></blockquote><blockquote><p><b>Radiotherapy Bolus</b></p><blockquote><p><b>url</b></p><code>type</code></blockquote><p><b>value</b>: 1 cm <span style=\"background: LightGoldenRodYellow; margin: 4px; border: 1px solid khaki\"> (radiotherapy-bolus#1 CM)</span></p><blockquote><p><b>url</b></p><code>frequency</code></blockquote><p><b>value</b>: Every Other Treatment <span style=\"background: LightGoldenRodYellow; margin: 4px; border: 1px solid khaki\"> (radiotherapy-bolus-frequency#EVERY OTHER TREATMENT)</span></p></blockquote><p><b>identifier</b>: id: 50 (use: OFFICIAL), id: Left Breast Boost (use: USUAL), id: Boost (use: SECONDARY)</p><p><b>basedOn</b>: <a href=\"ServiceRequest-RadiotherapyCoursePrescription-352-634.html\">ServiceRequest/RadiotherapyCoursePrescription-352-634: C1_Both_Breast</a></p><p><b>status</b>: active</p><p><b>intent</b>: original-order</p><p><b>category</b>: Radiation oncology AND/OR radiotherapy <span style=\"background: LightGoldenRodYellow; margin: 4px; border: 1px solid khaki\"> (<a href=\"https://browser.ihtsdotools.org/\">SNOMED CT</a>#108290001)</span></p><p><b>code</b>: Radiotherapy treatment phase (regime/therapy) <span style=\"background: LightGoldenRodYellow; margin: 4px; border: 1px solid khaki\"> (<a href=\"https://browser.ihtsdotools.org/\">SNOMED C