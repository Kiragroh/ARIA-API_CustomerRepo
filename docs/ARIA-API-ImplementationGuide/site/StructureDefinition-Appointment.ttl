       fhir:id [ fhir:v "Appointment.end" ] ;
       fhir:path [ fhir:v "Appointment.end" ] ;
       fhir:short [ fhir:v "Scheduled Date/Time at which the appointment is to conclude." ] ;
       fhir:comment [ fhir:v "Scheduled End Time" ]
     ] [
       fhir:id [ fhir:v "Appointment.minutesDuration" ] ;
       fhir:path [ fhir:v "Appointment.minutesDuration" ] ;
       fhir:short [ fhir:v "Duration" ] ;
       fhir:definition [ fhir:v "Number of minutes that the appointment is to take." ] ;
       fhir:comment [ fhir:v "Duration" ]
     ] [
       fhir:id [ fhir:v "Appointment.slot" ] ;
       fhir:path [ fhir:v "Appointment.slot" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Appointment.created" ] ;
       fhir:path [ fhir:v "Appointment.created" ] ;
       fhir:short [ fhir:v "Creation Time (Read Only | Auto generated while writing)" ] ;
       fhir:comment [ fhir:v "Creation Time" ]
     ] [
       fhir:id [ fhir:v "Appointment.comment" ] ;
       fhir:path [ fhir:v "Appointment.comment" ] ;
       fhir:short [ fhir:v "Additional comments about the appointment." ] ;
       fhir:comment [ fhir:v "Comment" ]
     ] [
       fhir:id [ fhir:v "Appointment.patientInstruction" ] ;
       fhir:path [ fhir:v "Appointment.patientInstruction" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Appointment.basedOn" ] ;
       fhir:path [ fhir:v "Appointment.basedOn" ] ;
       fhir:short [ fhir:v "Reference to Activity instance." ] ;
       fhir:definition [ fhir:v "Activity instance on which appointment is based on e.g ServiceRequest/ActivityInstance-{ActivityInstanceSer}." ] ;
       fhir:comment [ fhir:v "* If given in Http POST operation Appointment will be scheduled based on given Activity instance.\n\n* If not given in Http POST operation new activity instance will be created for appointmnt.\n\n* Http PUT operation will completly ignore this field.\n\n* Below validation will be performed-\n\n   * 1. Activity should not be scheduled.\n\n   * 2. Patient is mandatory to schedule appointment.\n\n   * 3. Activity should belong to given patient.\n\n   * 4. Activity should be present in Aria/DB.\n" ] ;
       fhir:max [ fhir:v "1" ]
     ] [
       fhir:id [ fhir:v "Appointment.participant.id" ] ;
       fhir:path [ fhir:v "Appointment.participant.id" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Appointment.participant.type" ] ;
       fhir:path [ fhir:v "Appointment.participant.type" ] ;
       fhir:short [ fhir:v "Role of participant in the appointment." ] ;
       fhir:definition [ fhir:v "Role of participant in the appointment e.g Patient|Practitioner|Device|Location| HelthCareService." ] ;
       fhir:comment [ fhir:v "* Following participant types are mappings are present.\n   * Standard Coding: \n      * System: http://hl7.org/fhir/ValueSet/encounter-participant-type \n      * Code:  PART (Participation)\n      * Display: ResourceName e.g. Patient, HealthcareService, Device \n \n      * Applicable for:  For All Appointment Resources ( Practitioner|Device | HealthcareService )and Patient\n   * Varian Coding:\n      * System: http://varian.com/fhir/CodeSystem/Appointment/SupportParticipationType\n      * Code:  checkin\n      * Display: checkin\n      * Applicable for:  Location\n\n* The role of the participant can be used to declare what the actor will be doing in the scope of this appointment.\n\nIf the actor is not specified, then it is expected that the actor will be filled in at a later stage of planning.\n\nThis value SHALL be the same when creating an AppointmentResponse so that they can be matched, and subsequently update the Appointment." ]
     ] [
       fhir:id [ fhir:v "Appointment.participant.actor" ] ;
       fhir:path [ fhir:v "Appointment.participant.actor" ] ;
       fhir:short [ fhir:v "Participant" ] ;
       fhir:definition [ fhir:v "Patient | Practitioner |  Device | HealthcareService | Location that is participating in the appointment." ] ;
       fhir:type ( [
         fhir:code [ fhir:v "Reference"^^xsd:anyURI ] ;
         fhir:targetProfile ( [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Patient"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Patient>
         ] [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Practitioner"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Practitioner>
         ] [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Device"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Device>
         ] [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/HealthcareService"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/HealthcareService>
         ] [
           fhir:v "http://varian.com/fhir/v1/StructureDefinition/Location"^^xsd:anyURI ;
           fhir:link <http://varian.com/fhir/v1/StructureDefinition/Location>
         ] )
       ] )
     ] [
       fhir:id [ fhir:v "Appointment.participant.required" ] ;
       fhir:path [ fhir:v "Appointment.participant.required" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Appointment.participant.status" ] ;
       fhir:path [ fhir:v "Appointment.participant.status" ] ;
       fhir:short [ fhir:v "Participation status of the actor as Accepted\nDefault value is Accepted." ] ;
       fhir:definition [ fhir:v "Participation status of the actor as Accepted." ] ;
       fhir:comment [ fhir:v "fixed → Accepted" ]
     ] [
       fhir:id [ fhir:v "Appointment.participant.period" ] ;
       fhir:path [ fhir:v "Appointment.participant.period" ] ;
       fhir:definition [ fhir:v "Arrival DateTime" ] ;
       fhir:comment [ fhir:v "Patient Location Arrival DateTime" ] ;
       fhir:max [ fhir:v "0" ]
     ] [
       fhir:id [ fhir:v "Appointment.requestedPeriod" ] ;
       fhir:path [ fhir:v "Appointment.requestedPeriod" ] ;
       fhir:max [ fhir:v "0" ]
     ] )
  ] . # 

